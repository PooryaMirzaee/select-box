# چنانچه Postgres با Dockerبالاست، خط بالا را کامنت و خط زیر را فعال کنید:
# DATABASE_URL=postgresql+psycopg2://selectbox:selectbox_dev@localhost:5432/selectbox

# بدون Docker — فایل SQLite در همین پوشه ایجاد می‌شود (مناسب توسعهٔ سریع)
DATABASE_URL=sqlite:///./selectbox_local.db

CORS_ORIGINS=http://localhost:3000

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=selectboxminio
MINIO_SECRET_KEY=selectboxminio_dev_change_me
MINIO_BUCKET=selectbox-assets
MINIO_SECURE=false

JWT_SECRET=change-me-in-production
PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DEV_OTP_CODE=123456

# ورود مشتری با پیامک — https://sms.ir/ (پنل → برنامه‌نویسان → API)
# می‌توانید از پنل ادمین (/admin/settings) هم تنظیم کنید
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=
SMS_IR_API_BASE=https://api.sms.ir

# درگاه — mock یا zarinpal (همچنین از پنل ادمین قابل تنظیم است)
PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true

# تولید — DEBUG=false و JWT_SECRET تصادفی حداقل ۳۲ کاراکتر
# DEBUG=false
# TRUSTED_HOSTS=yourdomain.com,api.yourdomain.com
# MOCK_PAYMENT_SECRET=
