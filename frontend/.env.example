# آدرس عمومی سایت — برای canonical، sitemap و Open Graph (در production دامنه واقعی)
SITE_URL=http://localhost:3000

# آدرس API — SSR و rewriteهای next.config
API_URL=http://localhost:8000

# مرورگر — در تولید با nginx یک‌دامنه‌ای خالی بگذارید (همان origin)
NEXT_PUBLIC_API_URL=http://localhost:8000
