# =============================================================================
# متغیرهای محیط تولید — کپی کنید به .env.production و مقادیر را پر کنید
# =============================================================================

# --- دامنه عمومی (با https در تولید) ---
PUBLIC_SITE_URL=https://example.com

# خالی بگذارید تا API از همان دامنه (پیشنهادی با nginx)
NEXT_PUBLIC_API_URL=

# پورت HTTP روی سرور (پشت reverse proxy مثل Caddy معمولاً 80)
HTTP_PORT=80

# --- Postgres ---
POSTGRES_USER=coralay
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=coralay

# --- MinIO (اختیاری — فعلاً در تولید استفاده نمی‌شود؛ آپلود روی volume محلی است) ---
# MINIO_ROOT_USER=coralayminio
# MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
# MINIO_BUCKET=coralay-assets

# --- امنیت API (حداقل ۳۲ کاراکتر تصادفی) ---
JWT_SECRET=CHANGE_ME_random_32_chars_minimum_here

# هاست‌های مجاز FastAPI — دامنه عمومی + سرویس‌های داخلی + localhost برای healthcheck
TRUSTED_HOSTS=example.com,www.example.com,nginx,api,localhost,127.0.0.1

# --- پرداخت ---
PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
MOCK_PAYMENT_SECRET=

# --- پیامک (sms.ir) ---
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=0
